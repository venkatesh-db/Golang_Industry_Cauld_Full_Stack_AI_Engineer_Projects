# Multi-stage build for the railcache service.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/railcache ./cmd/railcache

FROM alpine:3.20
RUN adduser -D -u 10001 app
USER app
COPY --from=build /out/railcache /railcache
EXPOSE 8080
ENTRYPOINT ["/railcache"]
